---
// Cart.astro
import { env } from '../infrastructure/config/env';
const whatsappNumber = env.PUBLIC_WHATSAPP_NUMBER;
---

<!-- Overlay del carrito -->
<div 
  id="cart-overlay" 
  class="fixed inset-0 z-50 bg-neutral-950/60 backdrop-blur-sm hidden transition-opacity duration-300 opacity-0"
>
  <!-- Sidebar -->
  <aside 
    id="cart-sidebar" 
    class="fixed top-0 right-0 bottom-0 w-full sm:max-w-md bg-neutral-950 border-l border-neutral-800 shadow-2xl flex flex-col translate-x-full transition-transform duration-300 ease-in-out"
  >
    <!-- Cabecera -->
    <div class="p-6 border-b border-neutral-800 flex items-center justify-between">
      <div class="flex items-center space-x-2">
        <h2 class="text-lg font-bold text-neutral-100 uppercase tracking-wider">Tu Carrito</h2>
        <span class="text-xs bg-gold-500/20 text-gold-400 font-semibold px-2 py-0.5 rounded border border-gold-500/30">★★★</span>
      </div>
      <button 
        id="cart-close" 
        class="text-neutral-400 hover:text-white hover:rotate-90 transition-all duration-300"
        aria-label="Cerrar carrito"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Lista de productos -->
    <div id="cart-items-container" class="flex-grow overflow-y-auto p-6 space-y-4">
      <!-- Los productos se inyectarán aquí dinámicamente con JavaScript -->
      <div class="text-center py-12 text-neutral-500 flex flex-col items-center justify-center space-y-3">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-neutral-700" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
        </svg>
        <p class="text-sm">Tu carrito está vacío.</p>
        <a href="/productos" class="text-xs text-celeste-400 hover:underline">Ir a ver camisetas</a>
      </div>
    </div>

    <!-- Indicador de tipo de compra (Mayorista / Minorista) -->
    <div id="wholesale-indicator" class="px-6 py-3 bg-neutral-900 border-t border-neutral-800 hidden">
      <!-- Inyectado por JS -->
    </div>

    <!-- Resumen y Checkout -->
    <div class="p-6 border-t border-neutral-800 bg-neutral-900/50 space-y-4">
      <div class="flex justify-between items-center text-sm">
        <span class="text-neutral-400">Total ítems:</span>
        <span id="cart-total-qty" class="font-bold text-neutral-200">0</span>
      </div>
      <div class="flex justify-between items-end">
        <span class="text-base font-medium text-neutral-300">Total Estimado:</span>
        <div class="text-right">
          <span id="cart-total-price" class="text-xl font-extrabold text-gold-400">$0</span>
        </div>
      </div>

      <button 
        id="cart-checkout-btn" 
        class="w-full bg-gold-500 hover:bg-gold-400 text-neutral-950 font-extrabold py-3.5 px-4 rounded-lg flex items-center justify-center gap-2 tracking-wide transition-all duration-300 shadow-md shadow-gold-500/10 disabled:opacity-40 disabled:pointer-events-none"
        disabled
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M18 10c0 3.866-3.582 7-8 7a8.841 8.841 0 01-4.083-.98L2 17l1.338-3.123C2.493 12.767 2 11.434 2 10c0-3.866 3.582-7 8-7s8 3.134 8 7zM7 9H5v2h2V9zm8 0h-2v2h2V9zM9 9h2v2H9V9z" clip-rule="evenodd" />
        </svg>
        Finalizar por WhatsApp
      </button>
    </div>
  </aside>
</div>

<script define:vars={{ whatsappNumber }}>
  // Variables y estado local del carrito
  let cart = [];

  // Elementos del DOM
  let overlay, sidebar, container, totalQtyEl, totalPriceEl, checkoutBtn, badgeEl, indicatorEl;

  function initElements() {
    overlay = document.getElementById('cart-overlay');
    sidebar = document.getElementById('cart-sidebar');
    container = document.getElementById('cart-items-container');
    totalQtyEl = document.getElementById('cart-total-qty');
    totalPriceEl = document.getElementById('cart-total-price');
    checkoutBtn = document.getElementById('cart-checkout-btn');
    indicatorEl = document.getElementById('wholesale-indicator');
    badgeEl = document.getElementById('cart-badge');
  }

  // Helper to escape HTML tags to prevent XSS
  function escapeHtml(str) {
    if (typeof str !== 'string') return '';
    return str
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  // Cargar carrito desde localStorage con soporte para versionado paraiso-cart-v2
  function loadCart() {
    const saved = localStorage.getItem('paraiso-cart-v2');
    let parsed = [];
    try {
      parsed = saved ? JSON.parse(saved) : [];
    } catch (e) {
      parsed = [];
    }

    if (Array.isArray(parsed)) {
      cart = parsed.filter(item => {
        return (
          item &&
          typeof item.id === 'string' &&
          typeof item.productId === 'number' &&
          typeof item.name === 'string' &&
          typeof item.sizeCode === 'string' &&
          typeof item.cantidad === 'number' &&
          !isNaN(item.cantidad) &&
          item.cantidad > 0 &&
          typeof item.retailPrice === 'number' &&
          (item.wholesalePrice === null || typeof item.wholesalePrice === 'number') &&
          typeof item.wholesaleMinimum === 'number'
        );
      });
    } else {
      cart = [];
    }
    updateCartUI();
  }

  // Guardar carrito en localStorage
  function saveCart() {
    localStorage.setItem('paraiso-cart-v2', JSON.stringify(cart));
    updateCartUI();
  }

  // Lógica de precios centralizada por producto
  function calculatePricing() {
    const qtyByProduct = {};
    cart.forEach(item => {
      qtyByProduct[item.productId] = (qtyByProduct[item.productId] || 0) + item.cantidad;
    });

    let total = 0;
    let retailTotal = 0;
    let savings = 0;

    const itemsWithPrices = cart.map(item => {
      const totalProductQty = qtyByProduct[item.productId] || 0;
      const qualifies = item.wholesalePrice !== null && totalProductQty >= item.wholesaleMinimum;
      const unitPrice = qualifies ? item.wholesalePrice : item.retailPrice;
      const lineSubtotal = unitPrice * item.cantidad;
      const lineRetailSubtotal = item.retailPrice * item.cantidad;

      total += lineSubtotal;
      retailTotal += lineRetailSubtotal;

      return {
        ...item,
        unitPrice,
        lineSubtotal,
        qualifies,
        totalProductQty
      };
    });

    savings = retailTotal - total;

    return {
      items: itemsWithPrices,
      total,
      retailTotal,
      savings,
      qtyByProduct
    };
  }

  // Actualizar la interfaz del carrito
  function updateCartUI() {
    if (!container) return;

    const pricing = calculatePricing();
    const totalQty = cart.reduce((sum, item) => sum + item.cantidad, 0);

    // Actualizar badges
    if (badgeEl) {
      badgeEl.innerText = totalQty;
      if (totalQty > 0) {
        badgeEl.classList.remove('scale-0');
        badgeEl.classList.add('scale-100');
      } else {
        badgeEl.classList.remove('scale-100');
        badgeEl.classList.add('scale-0');
      }
    }

    if (totalQtyEl) totalQtyEl.innerText = totalQty;
    
    if (totalPriceEl) {
      totalPriceEl.innerText = new Intl.NumberFormat('es-AR', {
        style: 'currency',
        currency: 'ARS',
        minimumFractionDigits: 0
      }).format(pricing.total);
    }

    // Configurar el indicador de compra mayorista y ahorro
    if (indicatorEl) {
      if (totalQty > 0) {
        indicatorEl.classList.remove('hidden');
        
        // Construir mensajes por producto que no califica
        let helperHtml = '';
        const uniqueProductIds = [...new Set(cart.map(i => i.productId))];
        
        uniqueProductIds.forEach(pid => {
          const itemSample = cart.find(i => i.productId === pid);
          if (!itemSample) return;
          const totalQtyForProd = pricing.qtyByProduct[pid] || 0;
          
          if (itemSample.wholesalePrice !== null) {
            if (totalQtyForProd < itemSample.wholesaleMinimum) {
              const missing = itemSample.wholesaleMinimum - totalQtyForProd;
              helperHtml += `
                <div class="text-[10px] text-neutral-400 mt-1 flex justify-between">
                  <span>• *${escapeHtml(itemSample.name)}*: faltan <strong class="text-celeste-400">${missing} u.</strong></span>
                  <span class="text-neutral-500">para precio mayorista</span>
                </div>
              `;
            }
          }
        });

        let summaryHtml = '';
        if (pricing.savings > 0) {
          summaryHtml += `
            <div class="flex items-center justify-between text-xs text-gold-400 font-bold">
              <span>🔥 AHORRO MAYORISTA APLICADO:</span>
              <span>-${new Intl.NumberFormat('es-AR', { style: 'currency', currency: 'ARS', minimumFractionDigits: 0 }).format(pricing.savings)}</span>
            </div>
          `;
        } else {
          summaryHtml += `
            <div class="text-xs text-neutral-300 font-semibold">
              Precios minoristas aplicados.
            </div>
          `;
        }

        indicatorEl.innerHTML = `
          <div class="space-y-1">
            ${summaryHtml}
            ${helperHtml}
          </div>
        `;
      } else {
        indicatorEl.classList.add('hidden');
      }
    }

    if (checkoutBtn) {
      checkoutBtn.disabled = cart.length === 0;
    }

    // Renderizar items
    if (cart.length === 0) {
      container.innerHTML = `
        <div class="text-center py-12 text-neutral-500 flex flex-col items-center justify-center space-y-3 h-full">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-neutral-800" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
          </svg>
          <p class="text-sm">Tu carrito está vacío.</p>
          <a href="/productos" class="text-xs text-celeste-400 hover:underline">Ir a ver catálogo</a>
        </div>
      `;
      return;
    }

    container.innerHTML = pricing.items.map(item => {
      const formattedItemPrice = new Intl.NumberFormat('es-AR', {
        style: 'currency',
        currency: 'ARS',
        minimumFractionDigits: 0
      }).format(item.lineSubtotal);

      const priceLabel = item.qualifies ? 'Mayorista' : 'Minorista';
      const badgeColor = item.qualifies ? 'text-gold-400 bg-gold-500/10 border-gold-500/20' : 'text-neutral-400 bg-neutral-900 border-neutral-800';

      const safeName = escapeHtml(item.name);
      const safeSizeCode = escapeHtml(item.sizeCode);
      const safeImagePath = escapeHtml(item.imagePath);
      const safeId = escapeHtml(item.id);

      return `
        <div class="flex items-center space-x-4 bg-neutral-900/50 p-3 rounded-lg border border-neutral-800/80">
          <div class="h-16 w-16 bg-neutral-950 rounded overflow-hidden flex-shrink-0 flex items-center justify-center border border-neutral-850">
            <img 
              src="${safeImagePath}" 
              alt="${safeName}" 
              class="h-full w-full object-contain" 
              onerror="this.onerror=null; this.src='/placeholder.svg';"
            />
          </div>
          <div class="flex-grow min-w-0">
            <h4 class="text-xs font-bold text-neutral-200 truncate">${safeName}</h4>
            <div class="flex items-center space-x-2 mt-0.5">
              <span class="text-[10px] text-neutral-400">Talle: <strong class="text-gold-400 font-extrabold">${safeSizeCode}</strong></span>
              <span class="text-[9px] px-1.5 py-0.2 rounded border ${badgeColor} font-semibold">${priceLabel}</span>
            </div>
            <p class="text-[10px] text-neutral-400 mt-1">
              ${new Intl.NumberFormat('es-AR', { style: 'currency', currency: 'ARS', minimumFractionDigits: 0 }).format(item.unitPrice)} c/u
            </p>
            <div class="flex items-center justify-between mt-2">
              <!-- Selectores de cantidad -->
              <div class="flex items-center space-x-1.5 bg-neutral-950 px-2 py-1 rounded border border-neutral-850">
                <button class="text-neutral-400 hover:text-white text-xs font-bold px-1 qty-btn-minus" data-id="${safeId}">-</button>
                <span class="text-xs font-semibold px-1 text-neutral-200">${item.cantidad}</span>
                <button class="text-neutral-400 hover:text-white text-xs font-bold px-1 qty-btn-plus" data-id="${safeId}">+</button>
              </div>
              <span class="text-xs font-extrabold text-neutral-100">${formattedItemPrice}</span>
            </div>
          </div>
        </div>
      `;
    }).join('');

    // Asignar listeners a los botones de sumar/restar creados dinámicamente
    document.querySelectorAll('.qty-btn-minus').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const target = e.target;
        if (target && typeof target.getAttribute === 'function') {
          const id = target.getAttribute('data-id');
          if (id) updateQty(id, -1);
        }
      });
    });

    document.querySelectorAll('.qty-btn-plus').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const target = e.target;
        if (target && typeof target.getAttribute === 'function') {
          const id = target.getAttribute('data-id');
          if (id) updateQty(id, 1);
        }
      });
    });
  }

  // Modificar cantidad de un ítem respetando el stock de variante
  function updateQty(id, delta) {
    const item = cart.find(i => i.id === id);
    if (!item) return;

    const newQty = item.cantidad + delta;
    if (newQty <= 0) {
      cart = cart.filter(i => i.id !== id);
    } else {
      // Evitar que la cantidad supere el stock de la variante
      const maxLimit = item.variantStock !== undefined ? item.variantStock : 99;
      if (newQty <= maxLimit) {
        item.cantidad = newQty;
      } else {
        item.cantidad = maxLimit;
      }
    }
    saveCart();
  }

  // Abrir / Cerrar el carrito
  function openCart() {
    if (!overlay || !sidebar) return;
    overlay.classList.remove('hidden');
    setTimeout(() => {
      overlay.classList.add('opacity-100');
      sidebar.classList.remove('translate-x-full');
    }, 10);
  }

  function closeCart() {
    if (!overlay || !sidebar) return;
    overlay.classList.remove('opacity-100');
    sidebar.classList.add('translate-x-full');
    setTimeout(() => {
      overlay.classList.add('hidden');
    }, 300);
  }

  // Enviar pedido a WhatsApp
  function checkout() {
    const pricing = calculatePricing();
    const totalQty = cart.reduce((sum, item) => sum + item.cantidad, 0);
    
    let listText = '';
    
    pricing.items.forEach(item => {
      const tipoPrecio = item.qualifies ? 'Mayorista 🔥' : 'Minorista';
      listText += `• *${item.name}* (Talle: ${item.sizeCode}) x${item.cantidad} _($${new Intl.NumberFormat('es-AR').format(item.unitPrice)} c/u - ${tipoPrecio})_\n`;
    });

    const totalFormatted = new Intl.NumberFormat('es-AR', { style: 'currency', currency: 'ARS', minimumFractionDigits: 0 }).format(pricing.total);
    
    const message = 
`⚽ *NUEVO PEDIDO - EL PARAÍSO DEL FÚTBOL* ⚽
------------------------------------------
Hola! Me gustaría encargar las siguientes camisetas:

${listText}
------------------------------------------
📦 *Cantidad total:* ${totalQty} productos
💰 *Total del pedido:* ${totalFormatted}

_Quedo a la espera para coordinar el pago y envío!_`;

    const encodedText = encodeURIComponent(message);
    const url = `https://wa.me/${whatsappNumber}?text=${encodedText}`;
    
    window.open(url, '_blank');
  }

  // Inicializar eventos en la carga del script de Astro
  document.addEventListener('astro:page-load', () => {
    initElements();
    loadCart();

    // Listener para abrir carrito
    const trigger = document.getElementById('cart-trigger');
    if (trigger) trigger.addEventListener('click', openCart);

    // Listener para cerrar carrito
    const closeBtn = document.getElementById('cart-close');
    if (closeBtn) closeBtn.addEventListener('click', closeCart);
    if (overlay) overlay.addEventListener('click', (e) => {
      if (e.target === overlay) closeCart();
    });

    // Listener para agregar items desde otros componentes
    document.addEventListener('add-to-cart', (e) => {
      const newItem = e.detail;
      const existing = cart.find(i => i.id === newItem.id);

      if (existing) {
        const potentialQty = existing.cantidad + newItem.cantidad;
        const maxLimit = newItem.variantStock !== undefined ? newItem.variantStock : 99;
        existing.cantidad = Math.min(potentialQty, maxLimit);
      } else {
        cart.push(newItem);
      }
      saveCart();
      openCart(); // Abrir sidebar automáticamente al añadir un item
    });

    // Responder a solicitudes de actualización
    document.addEventListener('request-cart-update', () => {
      updateCartUI();
    });

    // Checkout
    if (checkoutBtn) checkoutBtn.addEventListener('click', checkout);
  });
</script>

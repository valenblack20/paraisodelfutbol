---
// CamisetaCard.astro
interface Props {
  id: number;
  codigo_foto?: string;
  imagePath?: string;
  nombre: string;
  descripcion: string;
  precio_minorista: number;
  precio_mayorista: number;
  categoria: string;
  stock: number;
  featured?: boolean;
  badge?: string;
  imageFit?: 'contain' | 'cover';
}

const { 
  id, 
  codigo_foto, 
  imagePath,
  nombre, 
  descripcion, 
  precio_minorista, 
  precio_mayorista, 
  categoria, 
  stock,
  featured = false,
  badge,
  imageFit = 'contain'
} = Astro.props;

const imageSrc = imagePath || (codigo_foto ? `/Imagenes/${codigo_foto}.webp` : '/placeholder.svg');

// Formatear precios a pesos argentinos con dominio oficial https://paraisofutbol.com
const formatPrice = (price: number) => {
  return new Intl.NumberFormat('es-AR', {
    style: 'currency',
    currency: 'ARS',
    minimumFractionDigits: 0
  }).format(price);
};

const fitClass = imageFit === 'cover' ? 'object-cover' : 'object-contain';
---

<div 
  class={`product-card flex flex-col justify-between w-full h-full bg-[var(--color-surface)] border border-[var(--color-border)] hover:border-[var(--color-border-hover)] rounded-[var(--radius-card)] overflow-hidden shadow-[var(--shadow-card)] hover:shadow-[var(--shadow-card-hover)] hover:-translate-y-1 focus-within:ring-2 focus-within:ring-[var(--color-gold)] transition-all duration-300 group ${featured ? 'border-[var(--color-gold)] ring-1 ring-[var(--color-gold)]/30' : ''}`}
  data-id={id}
  data-nombre={nombre}
  data-precio-minorista={precio_minorista}
  data-precio-mayorista={precio_mayorista}
  data-codigo-foto={codigo_foto}
  data-categoria={categoria}
>
  
  <!-- Contenedor Foto con destello radial detrás -->
  <div class="relative aspect-[4/5] w-full bg-[#0a0a0a] overflow-hidden flex items-center justify-center p-6 border-b border-[var(--color-border)]">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_rgba(255,255,255,0.02)_0%,_transparent_70%)] pointer-events-none"></div>
    
    <img 
      src={imageSrc}
      alt={nombre}
      class={`w-full h-full max-h-full ${fitClass} group-hover:scale-[1.03] transition-transform duration-500`}
      loading="lazy"
      onerror="this.onerror=null; this.src='/placeholder.svg';"
    />
    
    <!-- Tag Categoría / Personalizado -->
    <span class="absolute top-4 left-4 bg-zinc-900/90 text-white text-[11px] font-bold px-3 py-1 rounded-full border border-[var(--color-border)] uppercase tracking-wider select-none">
      {badge || categoria}
    </span>

    <!-- Indicador Stock -->
    {stock <= 0 ? (
      <span class="absolute top-4 right-4 bg-red-950/90 text-red-400 text-[11px] font-bold px-3 py-1 rounded-full border border-red-800/40 uppercase tracking-wider select-none">
        Sin Stock
      </span>
    ) : stock < 5 ? (
      <span class="absolute top-4 right-4 bg-amber-950/90 text-amber-400 text-[11px] font-bold px-3 py-1 rounded-full border border-amber-800/40 uppercase tracking-wider select-none">
        Últimas {stock}
      </span>
    ) : null}

    {featured && (
      <span class="absolute bottom-4 left-4 bg-[var(--color-gold)] text-black text-[10px] font-extrabold px-2.5 py-0.5 rounded uppercase tracking-wider shadow select-none">
        Destacada
      </span>
    )}
  </div>

  <!-- Detalles de la Camiseta -->
  <div class="p-5 flex flex-col flex-grow justify-between">
    <div class="space-y-2">
      <!-- 3 estrellas del campeón con brillo unificado de marca -->
      <div class="flex text-[var(--color-gold)] space-x-1 text-xs select-none" aria-label="3 estrellas de calidad campeón">
        <span class="stars-shimmer font-bold text-sm">★</span>
        <span class="stars-shimmer font-bold text-sm">★</span>
        <span class="stars-shimmer font-bold text-sm">★</span>
      </div>

      <!-- Título: reserva espacio vertical para 2 líneas -->
      <h3 class="text-base font-bold text-[var(--color-text)] group-hover:text-[var(--color-gold)] transition-colors line-clamp-2 min-h-[3rem] flex items-center leading-snug">
        {nombre}
      </h3>

      <!-- Descripción breve: max 2 líneas -->
      <p class="text-xs text-[var(--color-text-muted)] line-clamp-2 leading-relaxed min-h-[2.5rem]">
        {descripcion || 'Camiseta de alta calidad con tecnología deportiva y detalles oficiales de alta definición.'}
      </p>
    </div>

    <!-- Caja de Precios y Botón -->
    <div class="mt-4 pt-4 border-t border-[var(--color-border)] space-y-4">
      <div class="space-y-1">
        <div class="flex items-baseline gap-2">
          <span class="text-xs text-[var(--color-text-muted)] font-medium">Precio:</span>
          <span class="text-2xl font-black text-[var(--color-text)] tracking-tight">
            {formatPrice(precio_minorista)}
          </span>
        </div>
        <p class="text-xs text-[var(--color-gold)] font-medium">
          Mayorista: <strong class="font-bold">{formatPrice(precio_mayorista)}</strong> <span class="text-zinc-500">(desde 6 u.)</span>
        </p>
      </div>

      <!-- Botón Agregar -->
      <button 
        class="w-full bg-[var(--color-gold)] text-black font-extrabold text-xs py-3.5 px-4 rounded-xl flex items-center justify-center gap-2 transition-all duration-300 disabled:bg-zinc-800 disabled:text-zinc-500 disabled:cursor-not-allowed add-to-cart-btn focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-gold)]"
        disabled={stock <= 0}
      >
        {stock <= 0 ? (
          <span>Sin stock</span>
        ) : (
          <>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
            </svg>
            <span>Agregar al Carrito</span>
          </>
        )}
      </button>
    </div>
  </div>
</div>

<script>
  // Añadir eventos a los botones de agregar al carrito de forma idempotente con View Transitions
  document.addEventListener('astro:page-load', () => {
    const cards = document.querySelectorAll('.product-card');
    
    cards.forEach(card => {
      const btn = card.querySelector('.add-to-cart-btn');
      if (!btn || btn.hasAttribute('data-listener-active')) return;

      btn.setAttribute('data-listener-active', 'true');
      btn.addEventListener('click', () => {
        const id = card.getAttribute('data-id');
        const nombre = card.getAttribute('data-nombre');
        const precioMinorista = parseFloat(card.getAttribute('data-precio-minorista') || '0');
        const precioMayorista = parseFloat(card.getAttribute('data-precio-mayorista') || '0');
        const codigoFoto = card.getAttribute('data-codigo-foto');

        const item = {
          id,
          nombre,
          precioMinorista,
          precioMayorista,
          codigoFoto,
          cantidad: 1
        };

        // Disparar evento global para añadir al carrito
        document.dispatchEvent(new CustomEvent('add-to-cart', { detail: item }));
        
        // Animación breve de feedback
        const oldContent = btn.innerHTML;
        btn.innerHTML = `
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          ¡Agregado!
        `;
        btn.classList.remove('bg-[var(--color-gold)]', 'text-black');
        btn.classList.add('bg-zinc-700', 'text-white');

        setTimeout(() => {
          btn.innerHTML = oldContent;
          btn.classList.remove('bg-zinc-700', 'text-white');
          btn.classList.add('bg-[var(--color-gold)]', 'text-black');
        }, 1200);
      });
    });
  });
</script>

---
// CamisetaCard.astro
interface Props {
  id: number;
  codigo_foto: string;
  nombre: string;
  descripcion: string;
  precio_minorista: number;
  precio_mayorista: number;
  categoria: string;
  stock: number;
}

const { id, codigo_foto, nombre, descripcion, precio_minorista, precio_mayorista, categoria, stock } = Astro.props;

// Formatear precios a pesos argentinos
const formatPrice = (price: number) => {
  return new Intl.NumberFormat('es-AR', {
    style: 'currency',
    currency: 'ARS',
    minimumFractionDigits: 0
  }).format(price);
};
---

<div 
  class="bg-neutral-900 border border-neutral-800 rounded-xl overflow-hidden shadow-lg hover:shadow-2xl hover:border-gold-500/50 hover:-translate-y-1 transition-all duration-300 flex flex-col group product-card"
  data-id={id}
  data-nombre={nombre}
  data-precio-minorista={precio_minorista}
  data-precio-mayorista={precio_mayorista}
  data-codigo-foto={codigo_foto}
  data-categoria={categoria}
>
  
  <!-- Contenedor Foto -->
  <div class="relative aspect-square w-full bg-neutral-950 overflow-hidden flex items-center justify-center">
    <img 
      src={`/Imagenes/${codigo_foto}.webp`}
      alt={nombre}
      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
      loading="lazy"
      onerror="this.onerror=null; this.src='https://placehold.co/600x600/0a0a0a/74ACDF?text=Paraiso+Del+Futbol';"
    />
    
    <!-- Tag Categoría -->
    <span class="absolute top-3 left-3 bg-neutral-950/80 backdrop-blur-md text-[10px] text-celeste-400 font-bold px-2.5 py-1 rounded-full border border-celeste-500/30 uppercase tracking-widest">
      {categoria}
    </span>

    <!-- Indicador Stock -->
    {stock <= 0 ? (
      <span class="absolute top-3 right-3 bg-red-950/80 backdrop-blur-md text-[10px] text-red-400 font-bold px-2.5 py-1 rounded-full border border-red-500/30 uppercase">
        Sin Stock
      </span>
    ) : stock < 5 ? (
      <span class="absolute top-3 right-3 bg-amber-950/80 backdrop-blur-md text-[10px] text-amber-400 font-bold px-2.5 py-1 rounded-full border border-amber-500/30 uppercase">
        Últimas {stock} disp.
      </span>
    ) : null}
  </div>

  <!-- Detalles de la Camiseta -->
  <div class="p-5 flex flex-col flex-grow">
    <!-- Estrellas Decorativas (3 Estrellas del Campeón) -->
    <div class="flex text-gold-500 space-x-0.5 mb-2 text-xs" aria-label="3 estrellas de calidad campeón">
      <span>★</span><span>★</span><span>★</span>
    </div>

    <!-- Título -->
    <h3 class="text-base font-bold text-neutral-100 group-hover:text-gold-400 transition-colors line-clamp-1">
      {nombre}
    </h3>

    <!-- Descripción breve -->
    <p class="text-xs text-neutral-400 mt-1 line-clamp-2 h-8 leading-relaxed">
      {descripcion || 'Camiseta de alta calidad con tecnología deportiva y escudo bordado.'}
    </p>

    <!-- Caja de Precios -->
    <div class="mt-4 pt-3 border-t border-neutral-800/60 grid grid-cols-2 gap-2">
      <div>
        <p class="text-[10px] text-neutral-500 font-semibold uppercase tracking-wider">Minorista</p>
        <p class="text-base font-extrabold text-neutral-200">{formatPrice(precio_minorista)}</p>
      </div>
      <div class="border-l border-neutral-800/80 pl-3">
        <p class="text-[10px] text-gold-500 font-semibold uppercase tracking-wider">Mayorista (+6 u.)</p>
        <p class="text-base font-extrabold text-gold-400">{formatPrice(precio_mayorista)}</p>
      </div>
    </div>

    <!-- Botón Agregar -->
    <div class="mt-5">
      <button 
        class="w-full bg-neutral-800 hover:bg-gold-500 text-neutral-200 hover:text-neutral-950 font-bold text-xs py-3 px-4 rounded-lg flex items-center justify-center gap-2 transition-all duration-300 disabled:opacity-50 disabled:pointer-events-none add-to-cart-btn"
        disabled={stock <= 0}
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
        </svg>
        Agregar al Carrito
      </button>
    </div>
  </div>
</div>

<script>
  // Añadir eventos a los botones de agregar al carrito
  document.addEventListener('astro:page-load', () => {
    const cards = document.querySelectorAll('.product-card');
    
    cards.forEach(card => {
      const btn = card.querySelector('.add-to-cart-btn');
      if (!btn) return;

      btn.addEventListener('click', () => {
        const id = card.getAttribute('data-id');
        const nombre = card.getAttribute('data-nombre');
        const precioMinorista = parseFloat(card.getAttribute('data-precio-minorista') || '0');
        const precioMayorista = parseFloat(card.getAttribute('data-precio-mayorista') || '0');
        const codigoFoto = card.getAttribute('data-codigo-foto');

        const item = {
          id,
          nombre,
          precioMinorista,
          precioMayorista,
          codigoFoto,
          cantidad: 1
        };

        // Disparar evento global para añadir al carrito
        document.dispatchEvent(new CustomEvent('add-to-cart', { detail: item }));
        
        // Animación breve de feedback
        const oldContent = btn.innerHTML;
        btn.innerHTML = `
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          ¡Agregado!
        `;
        btn.classList.remove('bg-neutral-800', 'text-neutral-200');
        btn.classList.add('bg-celeste-500', 'text-neutral-950');

        setTimeout(() => {
          btn.innerHTML = oldContent;
          btn.classList.remove('bg-celeste-500', 'text-neutral-950');
          btn.classList.add('bg-neutral-800', 'text-neutral-200');
        }, 1200);
      });
    });
  });
</script>

---
// CamisetaCard.astro
interface Props {
  id: number;
  slug: string;
  codigo_foto?: string;
  imagePath?: string;
  nombre: string;
  descripcion: string;
  precio_minorista: number;
  precio_mayorista: number;
  categoria: string;
  stock: number;
  featured?: boolean;
  badge?: string;
  imageFit?: 'contain' | 'cover';
}

const { 
  id, 
  slug,
  codigo_foto, 
  imagePath,
  nombre, 
  descripcion, 
  precio_minorista, 
  precio_mayorista, 
  stock,
  featured = false,
  badge,
  imageFit = 'contain'
} = Astro.props;

const imageSrc = imagePath || (codigo_foto ? `/Imagenes/${codigo_foto}.webp` : '/placeholder.svg');

// Formatear precios a pesos argentinos con dominio oficial https://paraisofutbol.com
const formatPrice = (price: number) => {
  return new Intl.NumberFormat('es-AR', {
    style: 'currency',
    currency: 'ARS',
    minimumFractionDigits: 0
  }).format(price);
};

const fitClass = imageFit === 'cover' ? 'object-cover' : 'object-contain';
---

<div 
  class="group product-card bg-neutral-900/40 rounded-2xl border border-[var(--color-border)] overflow-hidden flex flex-col h-full transition-all duration-300 hover:border-neutral-700 hover:shadow-xl hover:shadow-black/20"
  data-id={id}
  data-slug={slug}
  data-nombre={nombre}
  data-precio-minorista={precio_minorista}
  data-precio-mayorista={precio_mayorista}
  data-codigo-foto={codigo_foto}
>
  <!-- Contenedor Foto con destello radial detrás -->
  <a href={`/productos/${slug}`} class="relative aspect-[4/5] w-full bg-[#0a0a0a] overflow-hidden flex items-center justify-center p-6 border-b border-[var(--color-border)] group/img">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_rgba(255,255,255,0.02)_0%,_transparent_70%)] pointer-events-none"></div>
    
    <img 
      src={imageSrc}
      alt={nombre}
      class={`w-full h-full max-h-full ${fitClass} group-hover/img:scale-[1.02] transition-transform duration-500`}
      loading="lazy"
      onerror="this.onerror=null; this.src='/placeholder.svg';"
    />
    
    <!-- Tag Categoría / Personalizado -->
    {badge ? (
      <span class="absolute top-4 left-4 bg-celeste-500 text-neutral-950 text-[10px] font-extrabold px-2.5 py-0.5 rounded uppercase tracking-wider shadow select-none">
        {badge}
      </span>
    ) : (stock > 0 && 10 >= stock) ? (
      <span class="absolute top-4 right-4 bg-amber-950/90 text-amber-400 text-[11px] font-bold px-3 py-1 rounded-full border border-amber-800/40 uppercase tracking-wider select-none">
        Últimas {stock}
      </span>
    ) : null}

    {featured && (
      <span class="absolute bottom-4 left-4 bg-[var(--color-gold)] text-black text-[10px] font-extrabold px-2.5 py-0.5 rounded uppercase tracking-wider shadow select-none">
        Destacada
      </span>
    )}
  </a>

  <!-- Detalles de la Camiseta -->
  <div class="p-5 flex flex-col flex-grow justify-between">
    <div class="space-y-2">
      <!-- 3 estrellas del campeón con brillo unificado de marca -->
      <div class="flex text-[var(--color-gold)] space-x-1 text-xs select-none" aria-label="3 estrellas de calidad campeón">
        <span class="stars-shimmer font-bold text-sm">★</span>
        <span class="stars-shimmer font-bold text-sm">★</span>
        <span class="stars-shimmer font-bold text-sm">★</span>
      </div>

      <!-- Título: reserva espacio vertical para 2 líneas -->
      <h3 class="text-base font-bold text-[var(--color-text)] group-hover:text-[var(--color-gold)] transition-colors line-clamp-2 min-h-[3rem] flex items-center leading-snug">
        <a href={`/productos/${slug}`} class="hover:underline">{nombre}</a>
      </h3>

      <!-- Descripción breve: max 2 líneas -->
      <p class="text-xs text-[var(--color-text-muted)] line-clamp-2 leading-relaxed min-h-[2.5rem]">
        {descripcion || 'Camiseta de alta calidad con tecnología deportiva y detalles oficiales de alta definición.'}
      </p>
    </div>

    <!-- Caja de Precios y Botón -->
    <div class="mt-4 pt-4 border-t border-[var(--color-border)] space-y-4">
      <div class="space-y-1">
        <div class="flex items-baseline gap-2">
          <span class="text-xs text-[var(--color-text-muted)] font-medium">Precio:</span>
          <span class="text-2xl font-black text-[var(--color-text)] tracking-tight">
            {formatPrice(precio_minorista)}
          </span>
        </div>
        {precio_mayorista > 0 && (
          <p class="text-xs text-[var(--color-gold)] font-medium">
            Mayorista: <strong class="font-bold">{formatPrice(precio_mayorista)}</strong> <span class="text-zinc-500">(desde 6 u.)</span>
          </p>
        )}
      </div>

      <!-- Botón Ver Producto -->
      <a 
        href={`/productos/${slug}`}
        class="w-full bg-[var(--color-gold)] text-black font-extrabold text-xs py-3.5 px-4 rounded-xl flex items-center justify-center gap-2 transition-all duration-300 hover:bg-gold-400 text-center active:scale-95 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-gold)]"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
        </svg>
        <span>Ver Producto</span>
      </a>
    </div>
  </div>
</div>

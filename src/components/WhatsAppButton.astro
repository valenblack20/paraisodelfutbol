---
// WhatsAppButton.astro
const whatsappNumber = process.env.WHATSAPP_NUMBER || '5491100000000';
const defaultMessage = encodeURIComponent('¡Hola! Me gustaría hacer una consulta sobre las camisetas de fútbol.');
const waUrl = `https://wa.me/${whatsappNumber}?text=${defaultMessage}`;
---

<a 
  href={waUrl}
  target="_blank"
  rel="noopener noreferrer"
  class="fixed bottom-6 right-6 z-30 bg-emerald-500 hover:bg-emerald-400 text-white p-4 rounded-full shadow-2xl hover:scale-110 active:scale-95 transition-all duration-300 group flex items-center justify-center"
  aria-label="Contactar por WhatsApp"
>
  <!-- Efecto de pulso en el fondo -->
  <span class="absolute inset-0 rounded-full bg-emerald-500/40 animate-ping group-hover:animate-none"></span>
  
  <!-- Icono de WhatsApp -->
  <svg 
    xmlns="http://www.w3.org/2000/svg" 
    class="h-7 w-7 relative z-10" 
    viewBox="0 0 24 24" 
    fill="currentColor"
  >
    <path 
      fill-rule="evenodd" 
      d="M1.5 10.5a8.94 8.94 0 011.66-5.185l-1.15-3.45a.75.75 0 01.947-.947l3.45 1.15A8.942 8.942 0 0110.5 1.5c5.247 0 9.5 4.253 9.5 9.5 0 5.247-4.253 9.5-9.5 9.5-1.802 0-3.486-.502-4.922-1.375l-4.14 1.38a.75.75 0 01-.947-.947l1.38-4.14A8.942 8.942 0 011.5 10.5zm9 5.5c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4z" 
      clip-rule="evenodd" 
    />
    <path 
      d="M12.012 6.012c-.228-.48-.48-.488-.703-.497-.18-.008-.388-.008-.596-.008a1.2 1.2 0 00-.87.408c-.3.33-1.148 1.122-1.148 2.73 0 1.61 1.173 3.167 1.334 3.385.165.218 2.308 3.525 5.59 4.95 2.73 1.185 3.285.952 3.885.892.6-.06 1.935-.79 2.205-1.553.27-.765.27-1.425.188-1.56-.082-.135-.3-.218-.63-.383-.33-.165-1.935-.953-2.235-1.065-.3-.113-.518-.165-.735.165-.218.33-.84 1.065-1.028 1.283-.187.217-.375.24-.705.075-.33-.165-1.395-.51-2.655-1.635-1-.892-1.673-1.995-1.87-2.332-.195-.338-.022-.52.143-.685.15-.143.33-.383.495-.578.165-.195.218-.33.33-.548.113-.218.06-.405-.03-.57-.083-.165-.705-1.7-.975-2.355z"
    />
  </svg>

  <!-- Tooltip flotante al hacer hover -->
  <span class="absolute right-16 bg-neutral-900 text-neutral-100 text-xs font-semibold px-3 py-1.5 rounded-lg border border-neutral-800 opacity-0 pointer-events-none group-hover:opacity-100 transition-opacity duration-300 whitespace-nowrap shadow-xl">
    ¿Tenés dudas? Escribinos!
  </span>
</a>

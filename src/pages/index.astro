---
import Layout from '../layouts/Layout.astro';
import CamisetaCard from '../components/CamisetaCard.astro';
import { query } from '../lib/db.js';

// Habilitamos rendering híbrido (estático por defecto, pero con llamadas dinámicas si es necesario)
export const prerender = true;

// Obtener las camisetas más buscadas (primeras 3 de la base de datos)
let camisetasDestacadas = [];
try {
  camisetasDestacadas = await query('SELECT * FROM camisetas LIMIT 3');
} catch (e) {
  console.error('Error cargando camisetas destacadas:', e);
}
---

<Layout title="Inicio - Campeones de la Calidad">
  
  <!-- HERO BANNER -->
  <section class="relative min-h-[85vh] flex items-center justify-center overflow-hidden bg-neutral-950 border-b border-neutral-900 py-16">
    <!-- Fondos con acentos celestes y dorados -->
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-celeste-950/20 via-neutral-950 to-neutral-950 z-0"></div>
    <div class="absolute top-0 left-1/4 w-96 h-96 bg-celeste-500/10 rounded-full blur-[120px] pointer-events-none"></div>
    <div class="bottom-0 right-1/4 w-96 h-96 bg-gold-500/5 rounded-full blur-[150px] pointer-events-none"></div>

    <!-- Contenedor de Confeti (Papelitos) -->
    <div id="hero-confetti" class="absolute inset-0 pointer-events-none overflow-hidden z-0"></div>

    <!-- Contenido del Hero -->
    <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center flex flex-col items-center">
      <!-- Tres estrellas del Campeón -->
      <div class="flex justify-center text-gold-400 text-3xl sm:text-4xl md:text-5xl gap-2 mb-6 select-none">
        <span class="stars-shimmer">★</span><span class="stars-shimmer scale-125 -translate-y-1.5">★</span><span class="stars-shimmer">★</span>
      </div>

      <!-- Título Principal -->
      <h1 class="text-4xl sm:text-6xl md:text-7xl font-extrabold tracking-tight uppercase leading-none max-w-4xl font-display">
        <span class="text-neutral-100 block">Vesti la pasión del</span>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-celeste-400 via-white to-gold-400 block mt-2">
          Campeón del Mundo
        </span>
      </h1>

      <!-- Descripción -->
      <p class="mt-6 text-base sm:text-lg md:text-xl text-neutral-400 max-w-2xl leading-relaxed">
        Encontrá las camisetas más épicas de clubes y selecciones. Calidad premium importada al mejor precio para compras minoristas y mayoristas.
      </p>

      <!-- Botones de Acción -->
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center w-full max-w-md">
        <a 
          href="/productos" 
          class="bg-gold-500 hover:bg-gold-400 text-neutral-950 font-extrabold px-8 py-4 rounded-xl text-sm uppercase tracking-wider transition-all duration-300 shadow-lg shadow-gold-500/20 hover:scale-105"
        >
          Explorar Catálogo
        </a>
        <a 
          href="/nosotros" 
          class="bg-neutral-900 hover:bg-neutral-800 text-neutral-200 border border-neutral-800 hover:border-neutral-700 px-8 py-4 rounded-xl text-sm uppercase tracking-wider transition-all duration-300 hover:scale-105"
        >
          Nuestra Historia
        </a>
      </div>

      <!-- Detalle Visual de Copa / Selección -->
      <div class="mt-16 border-t border-neutral-900 pt-8 w-full max-w-4xl grid grid-cols-3 gap-4 text-center">
        <div>
          <span class="block text-2xl md:text-3xl font-extrabold text-celeste-400 font-display">100%</span>
          <span class="text-[10px] uppercase text-neutral-500 font-bold tracking-widest mt-1 block">Calidad Premium</span>
        </div>
        <div class="border-x border-neutral-900">
          <span class="block text-2xl md:text-3xl font-extrabold text-gold-400 font-display">+6 U.</span>
          <span class="text-[10px] uppercase text-neutral-500 font-bold tracking-widest mt-1 block">Precio Mayorista</span>
        </div>
        <div>
          <span class="block text-2xl md:text-3xl font-extrabold text-celeste-400 font-display">Envíos</span>
          <span class="text-[10px] uppercase text-neutral-500 font-bold tracking-widest mt-1 block">Todo el País</span>
        </div>
      </div>
    </div>
  </section>

  <!-- BANNER INFORMATIVO -->
  <section class="bg-gradient-to-r from-neutral-950 via-neutral-900 to-neutral-950 border-y border-neutral-900 py-6">
    <div class="max-w-7xl mx-auto px-4 overflow-hidden">
      <div class="flex justify-around items-center gap-8 text-xs font-semibold tracking-wider text-neutral-300 uppercase whitespace-nowrap overflow-x-auto py-2">
        <span class="flex items-center gap-2">
          <span class="text-gold-500 text-base">✓</span> Ventas Mayoristas & Minoristas
        </span>
        <span class="text-neutral-700 select-none">|</span>
        <span class="flex items-center gap-2">
          <span class="text-celeste-400 text-base">✈</span> Envíos a todo el país por Correo Argentino
        </span>
        <span class="text-neutral-700 select-none">|</span>
        <span class="flex items-center gap-2">
          <span class="text-gold-500 text-base">★</span> Tres Estrellas Doradas Calidad Premium
        </span>
      </div>
    </div>
  </section>

  <!-- SECCIÓN "LAS MÁS BUSCADAS" -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex flex-col md:flex-row justify-between items-end mb-12">
      <div>
        <span class="text-xs text-celeste-400 font-bold tracking-widest uppercase">Camisetas Destacadas</span>
        <h2 class="text-3xl font-extrabold uppercase mt-2 font-display">
          Las Más <span class="text-gold-500">Buscadas</span>
        </h2>
      </div>
      <a 
        href="/productos" 
        class="mt-4 md:mt-0 text-sm text-neutral-400 hover:text-gold-400 font-semibold flex items-center gap-1.5 transition-colors group"
      >
        Ver todas las camisetas
        <span class="group-hover:translate-x-1 transition-transform">&rarr;</span>
      </a>
    </div>

    <!-- Listado de Camisetas -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {camisetasDestacadas.map((camiseta) => (
        <CamisetaCard 
          id={camiseta.id}
          codigo_foto={camiseta.codigo_foto}
          nombre={camiseta.nombre}
          descripcion={camiseta.descripcion}
          precio_minorista={Number(camiseta.precio_minorista)}
          precio_mayorista={Number(camiseta.precio_mayorista)}
          categoria={camiseta.categoria}
          stock={camiseta.stock}
        />
      ))}
    </div>
  </section>

  <!-- Separador Patrio de Sección -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <hr class="separator-patrio" />
  </div>

  <!-- SECCIÓN BANNER PUBLICITARIO / RIVALES -->
  <section class="bg-neutral-900/60 py-16 relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      
      <!-- Lado Texto -->
      <div class="space-y-6">
        <div class="inline-flex items-center space-x-1 bg-gold-500/10 text-gold-400 text-[10px] font-bold px-3 py-1 rounded-full border border-gold-500/20 uppercase tracking-widest">
          <span>Colección Especial</span>
          <span>★★★</span>
        </div>
        <h2 class="text-3xl sm:text-4xl font-extrabold uppercase leading-tight font-display">
          ¿Listo para lucir los colores de la gloria eterna?
        </h2>
        <p class="text-sm text-neutral-400 leading-relaxed">
          Reviví la final del mundo contra Francia, alentá a tu club local o llevá la pilcha de los mejores equipos de Europa. Nuestras camisetas tienen todos los parches oficiales, costuras reforzadas y escudos bordados de alta definición.
        </p>
        <div class="pt-4">
          <a 
            href="/productos" 
            class="inline-block bg-celeste-500 hover:bg-celeste-400 text-neutral-950 font-bold px-8 py-3.5 rounded-lg text-xs uppercase tracking-wider transition-all duration-300 shadow-md shadow-celeste-500/10"
          >
            Ver Catálogo
          </a>
        </div>
      </div>

      <!-- Lado Imagen Placeholder Estético / Generado -->
      <div class="relative aspect-video rounded-2xl overflow-hidden border border-neutral-800 bg-neutral-950 flex items-center justify-center p-8">
        <!-- Fondo de Muestra -->
        <div class="absolute inset-0 bg-gradient-to-tr from-neutral-950 via-neutral-900/50 to-celeste-950/20"></div>
        <div class="relative z-10 text-center space-y-4 max-w-sm">
          <span class="text-gold-500 text-3xl font-extrabold block font-display">EL TEMPLO DEL HINCHA</span>
          <p class="text-xs text-neutral-400 leading-relaxed">
            Hacemos que comprar tu camiseta sea tan simple como gritar un gol. Recibila en tu casa en 72hs hábiles.
          </p>
        </div>
      </div>

    </div>
  </section>

</Layout>

<script>
  // Generación dinámica de papelitos (confeti) flotando lentamente en el Hero
  const setupConfetti = () => {
    const container = document.getElementById('hero-confetti');
    if (!container) return;
    container.innerHTML = '';
    const colors = ['#74ACDF', '#FFFFFF', '#D4AF37'];
    for (let i = 0; i < 35; i++) {
      const confetti = document.createElement('div');
      confetti.style.position = 'absolute';
      confetti.style.width = `${Math.random() * 8 + 4}px`;
      confetti.style.height = `${Math.random() * 12 + 6}px`;
      confetti.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
      confetti.style.left = `${Math.random() * 100}%`;
      confetti.style.top = `-${Math.random() * 20 + 20}px`;
      confetti.style.opacity = (Math.random() * 0.6 + 0.3).toString();
      confetti.style.transform = `rotate(${Math.random() * 360}deg)`;
      
      const duration = Math.random() * 7 + 5;
      const delay = Math.random() * 5;
      
      confetti.style.animation = `fall ${duration}s linear infinite`;
      confetti.style.animationDelay = `${delay}s`;
      
      container.appendChild(confetti);
    }
  };

  document.addEventListener('astro:page-load', setupConfetti);
</script>

<style is:global>
  @keyframes fall {
    0% {
      transform: translateY(0) rotate(0deg) translateX(0);
    }
    35% {
      transform: translateY(30vh) rotate(120deg) translateX(15px);
    }
    70% {
      transform: translateY(60vh) rotate(240deg) translateX(-15px);
    }
    100% {
      transform: translateY(95vh) rotate(360deg) translateX(5px);
    }
  }
</style>

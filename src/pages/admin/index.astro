---
// src/pages/admin/index.astro
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getDatabasePool } from '../../infrastructure/database/mysql';

const adminContext = (Astro.locals as any).admin;
if (!adminContext.authenticated || !adminContext.user || !adminContext.session) {
  return Astro.redirect('/admin/login');
}

let dbStatusMessage = 'Desconectado ❌';
let dbStatusClass = 'text-red-400 border-red-500/20 bg-red-950/20';

let totalProducts = 0;
let totalCategories = 0;
let totalStock = 0;

try {
  const pool = getDatabasePool();
  await pool.query('SELECT 1');
  dbStatusMessage = 'MySQL Online ✅';
  dbStatusClass = 'text-emerald-400 border-emerald-500/20 bg-emerald-950/20';

  const [prodRows] = await pool.execute('SELECT COUNT(*) as cnt FROM products WHERE archived = FALSE');
  totalProducts = (prodRows as any[])[0].cnt || 0;

  const [catRows] = await pool.execute('SELECT COUNT(*) as cnt FROM categories');
  totalCategories = (catRows as any[])[0].cnt || 0;

  const [stockRows] = await pool.execute('SELECT SUM(stock) as total FROM product_variants WHERE active = TRUE');
  totalStock = Number((stockRows as any[])[0].total || 0);
} catch (error) {
  console.error('[Admin DB Check] Connection failure:', error);
}
---

<AdminLayout title="Panel de Administración">
  <div class="space-y-8">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 border-b border-neutral-900 pb-6">
      <div>
        <h1 class="text-2xl font-black uppercase text-white tracking-wide">Resumen General</h1>
        <p class="text-xs text-neutral-400 mt-1">Estado en tiempo real de tu tienda y base de datos.</p>
      </div>
      <div>
        <span class={`border rounded-xl px-4 py-2 text-xs font-bold ${dbStatusClass}`}>
          {dbStatusMessage}
        </span>
      </div>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
      <!-- Products Card -->
      <div class="bg-[#161616]/40 border border-neutral-850 rounded-2xl p-6 space-y-2">
        <span class="text-2xl">👕</span>
        <h3 class="text-xs font-bold uppercase tracking-wider text-neutral-400">Camisetas Activas</h3>
        <p class="text-3xl font-black text-white">{totalProducts}</p>
      </div>

      <!-- Categories Card -->
      <div class="bg-[#161616]/40 border border-neutral-850 rounded-2xl p-6 space-y-2">
        <span class="text-2xl">📁</span>
        <h3 class="text-xs font-bold uppercase tracking-wider text-neutral-400">Categorías</h3>
        <p class="text-3xl font-black text-white">{totalCategories}</p>
      </div>

      <!-- Stock Card -->
      <div class="bg-[#161616]/40 border border-neutral-850 rounded-2xl p-6 space-y-2">
        <span class="text-2xl">📦</span>
        <h3 class="text-xs font-bold uppercase tracking-wider text-neutral-400">Stock Total</h3>
        <p class="text-3xl font-black text-white">{totalStock} uds.</p>
      </div>
    </div>

    <!-- Quick actions / Guide -->
    <div class="bg-[#161616]/30 border border-neutral-850/60 rounded-2xl p-6 space-y-4">
      <h3 class="text-sm font-bold text-white uppercase tracking-wider">Accesos Rápidos</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <a 
          href="/admin/products" 
          class="flex items-center justify-between p-4 bg-[#121212] hover:bg-neutral-900 border border-neutral-850 rounded-xl text-xs font-bold text-neutral-200 transition-colors"
        >
          <span>Ir a Administrar Camisetas</span>
          <span class="text-[#D4AF37]">&rarr;</span>
        </a>
        <a 
          href="/admin/categories" 
          class="flex items-center justify-between p-4 bg-[#121212] hover:bg-neutral-900 border border-neutral-850 rounded-xl text-xs font-bold text-neutral-200 transition-colors"
        >
          <span>Ir a Administrar Categorías</span>
          <span class="text-[#D4AF37]">&rarr;</span>
        </a>
      </div>
    </div>
  </div>
</AdminLayout>

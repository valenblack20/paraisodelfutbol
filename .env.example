# Configuración de Base de Datos MySQL
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_CONNECTION_LIMIT=10
DB_SSL=false

# Configuración de Entorno e URLs de Sitio
NODE_ENV=development
PUBLIC_SITE_URL=https://paraisofutbol.com

# Configuración de WhatsApp
# Formato: código de país + código de área + número (sin espacios ni guiones)
# Ejemplo para Argentina: 5491123456789
WHATSAPP_NUMBER=
PUBLIC_WHATSAPP_NUMBER=

# Seguridad y Admin
ENABLE_UNSAFE_ADMIN=false
AUTH_RATE_LIMIT_PEPPER=
ADMIN_SESSION_HOURS=8
COOKIE_SECURE=true
TRUST_PROXY=false
